    {
        "name": "Formulario Login",
        "icon": "🔐",
        "description": "Formulario de inicio de sesión",
        "category": "forms",
        "html": "<form class=\"form form-login\">\n    <h2 class=\"form-title\">Iniciar Sesión</h2>\n    <div class=\"form-group\">\n        <label for=\"login-email\">Email</label>\n        <input type=\"email\" id=\"login-email\" class=\"form-control\" placeholder=\"tu@email.com\" required>\n    </div>\n    <div class=\"form-group\">\n        <label for=\"login-password\">Contraseña</label>\n        <input type=\"password\" id=\"login-password\" class=\"form-control\" placeholder=\"••••••••\" required>\n    </div>\n    <div class=\"form-check\">\n        <input type=\"checkbox\" id=\"remember\" class=\"form-check-input\">\n        <label for=\"remember\" class=\"form-check-label\">Recordarme</label>\n    </div>\n    <button type=\"submit\" class=\"btn btn-primary btn-block\">Iniciar Sesión</button>\n    <p class=\"form-footer\"><a href=\"#\">¿Olvidaste tu contraseña?</a></p>\n</form>",
        "css": ".form-login { max-width: 400px; margin: 0 auto; padding: 30px; background: #1e293b; border-radius: 12px; } .form-title { text-align: center; color: #e2e8f0; margin-bottom: 30px; } .form-footer { text-align: center; margin-top: 20px; } .form-footer a { color: #3b82f6; text-decoration: none; }"
    },
    {
        "name": "Input con Icono",
        "icon": "🔍",
        "description": "Campo con icono",
        "category": "forms",
        "html": "<div class=\"form-group\">\n    <label for=\"search\">Buscar</label>\n    <div class=\"input-group\">\n        <span class=\"input-icon\"><i class=\"fas fa-search\"></i></span>\n        <input type=\"text\" id=\"search\" class=\"form-control input-with-icon\" placeholder=\"Buscar...\">\n    </div>\n</div>",
        "css": ".input-group { position: relative; } .input-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #64748b; z-index: 1; } .input-with-icon { padding-left: 40px; }"
